<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
    <div class="container-fluid px-4">
        <!-- Логотип (только текст, без картинки) -->
        <a class="navbar-brand fw-bold fs-3 text-primary" href="/">
            🎯 HabitTracker
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                        🏠 Главная
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link" href="habits">
                        📋 Доска привычек
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link" href="stats">
                        📈 Статистика
                    </NavLink>
                </li>
            </ul>

            <div class="d-flex align-items-center gap-2">
                @if (Auth.IsAuthenticated)
                {
                    <button class="btn btn-outline-danger btn-sm px-3" @onclick="Logout">
                        🚪 Выйти
                    </button>
                }
                else
                {
                    <a href="login" class="btn btn-outline-primary btn-sm px-4">🔐 Вход</a>
                    <a href="register" class="btn btn-primary btn-sm px-4">📝 Регистрация</a>
                }
            </div>
        </div>
    </div>
</nav>

@code {
    [Inject] private AuthService Auth { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    protected override void OnInitialized()
    {
        Auth.OnAuthStateChanged += () => InvokeAsync(StateHasChanged);
    }

    private async Task Logout()
    {
        await Auth.Logout();
        Navigation.NavigateTo("/", forceLoad: true);
    }
}