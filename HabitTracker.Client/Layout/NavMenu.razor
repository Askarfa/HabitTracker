<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
    <div class="container-fluid px-4">
        <!-- Логотип -->
        <a class="navbar-brand d-flex align-items-center" href="">
            <img src="logo.png" alt="HabitTracker" style="width: 32px; height: 32px; margin-right: 10px;" />
            <span style="font-weight: 700; color: #6366f1; font-size: 1.5rem;">HabitTracker</span>
        </a>

        <!-- Кнопка для мобильных -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- Меню -->
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <span class="nav-icon">🏠</span> Главная
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link" href="habits">
                        <span class="nav-icon">📋</span> Привычки
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link" href="kanban">
                        <span class="nav-icon">📊</span> Доска
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link" href="stats">
                        <span class="nav-icon">📈</span> Статистика
                    </NavLink>
                </li>
            </ul>

            <!-- Кнопки справа -->
            <div class="d-flex align-items-center gap-2">
                @if (Auth.IsAuthenticated)
                {
                    <button class="btn btn-outline-danger btn-sm px-3" @onclick="Logout">
                        🚪 Выйти
                    </button>
                }
                else
                {
                    <a href="login" class="btn btn-outline-primary btn-sm px-4" style="min-width: 100px;">
                        🔐 Вход
                    </a>
                    <a href="register" class="btn btn-primary btn-sm px-4">
                        📝 Регистрация
                    </a>
                }
            </div>
        </div>
    </div>
</nav>

@code {
    [Inject] private AuthService Auth { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    // ← ДОБАВЬТЕ ЭТО:
    protected override void OnInitialized()
    {
        Auth.OnAuthStateChanged += () => InvokeAsync(StateHasChanged);
    }

    private async Task Logout()
    {
        await Auth.Logout();
        Navigation.NavigateTo("/", forceLoad: true);
    }
}