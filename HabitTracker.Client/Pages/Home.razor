@page "/"
@using HabitTracker.Client.Models
@using HabitTracker.Client.Services
@inject HttpClient Http
@inject AuthService Auth
@inject NavigationManager Navigation

<PageTitle>Мои привычки</PageTitle>

<h3>📋 Мои привычки сегодня</h3>

@if (!Auth.IsAuthenticated)
{
    <div class="alert alert-info">
        <p>👋 Добро пожаловать! Пожалуйста, <a href="/login">войдите</a> или <a href="/register">зарегистрируйтесь</a> чтобы отслеживать привычки.</p>
    </div>
}
else if (habits == null)
{
    <p><span class="spinner-border spinner-border-sm text-primary"></span> Загрузка привычек...</p>
}
else if (habits.Count == 0)
{
    <div class="alert alert-info">
        <p>🎉 У вас пока нет привычек!</p>
        <a href="/habits/create" class="btn btn-success">
            <span class="bi bi-plus-circle"></span> Создать первую привычку
        </a>
    </div>
}
else
{
    <!-- Статистика -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h5 class="card-title">📊 Всего привычек</h5>
                    <p class="card-title display-6">@habits.Count</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5 class="card-title">✅ Выполнено сегодня</h5>
                    <p class="card-title display-6">@habits.Count(h => h.IsCompletedToday)</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-warning text-dark">
                <div class="card-body">
                    <h5 class="card-title">⏳ Осталось</h5>
                    <p class="card-title display-6">@habits.Count(h => !h.IsCompletedToday)</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Список привычек -->
    <div class="row">
        @foreach (var habit in habits.OrderBy(h => h.IsCompletedToday).ThenBy(h => h.Name))
        {
            <div class="col-md-6 col-lg-4 mb-3">
                <div class="card h-100 @(habit.IsCompletedToday ? "border-success bg-light" : "border-warning")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0">@habit.Name</h5>
                            @if (habit.IsCompletedToday)
                            {
                                <span class="badge bg-success">✅</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">⏳</span>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(habit.Description))
                        {
                            <p class="card-text text-muted small">@habit.Description</p>
                        }

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="badge @(habit.CurrentStreak >= habit.TargetStreak ? "bg-success" : "bg-warning text-dark")">
                                🔥 @habit.CurrentStreak/@habit.TargetStreak
                            </span>
                            <small class="text-muted">@GetFrequencyText(habit.Frequency)</small>
                        </div>

                        @if (!habit.IsCompletedToday)
                        {
                            <button class="btn btn-success btn-sm w-100"
                                    onclick="@(() => MarkAsCompleted(habit.Id))"
                                    disabled="@isCompleting">
                                @if (isCompleting && completingId == habit.Id)
                                {
                                    <span class="spinner-border spinner-border-sm"></span> <text>Выполняем...</text>
                                }
                                else
                                {
                                    <span class="bi bi-check-circle"></span> <text>Отметить выполненным</text>
                                }
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-secondary btn-sm w-100" disabled>
                                <span class="bi bi-check2-all"></span> <text>Выполнено сегодня</text>
                            </button>
                        }
                    </div>
                    <div class="card-footer bg-transparent">
                        <a href="/habits/edit/@habit.Id" class="btn btn-outline-primary btn-sm w-100">
                            <span class="bi bi-pencil"></span> Редактировать
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Кнопка добавить -->
    <div class="mt-4">
        <a href="/habits/create" class="btn btn-primary">
            <span class="bi bi-plus-circle"></span> Добавить новую привычку
        </a>
        <a href="/habits" class="btn btn-outline-secondary ms-2">
            <span class="bi bi-list"></span> Все привычки
        </a>
    </div>
}

@code {
    private List<HabitModel>? habits;
    private bool isCompleting = false;
    private Guid completingId;

    protected override async Task OnInitializedAsync()
    {
        if (Auth.IsAuthenticated)
        {
            await LoadHabits();
        }
    }

    private async Task LoadHabits()
    {
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, "/api/habits");

            var token = Auth.GetToken();
            if (!string.IsNullOrEmpty(token))
            {
                request.Headers.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                habits = await response.Content.ReadFromJsonAsync<List<HabitModel>>();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                Auth.Logout();
                Navigation.NavigateTo("/login");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки привычек: {ex.Message}");
        }
    }

    private async Task MarkAsCompleted(Guid id)
    {
        isCompleting = true;
        completingId = id;
        StateHasChanged();

        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Post, $"/api/habit-logs/{id}/complete");

            var token = Auth.GetToken();
            if (!string.IsNullOrEmpty(token))
            {
                request.Headers.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                await LoadHabits();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка: {ex.Message}");
        }
        finally
        {
            isCompleting = false;
            StateHasChanged();
        }
    }

    private string GetFrequencyText(int frequency)
    {
        return frequency switch
        {
            0 => "Ежедневно",
            1 => "Еженедельно",
            2 => "Ежемесячно",
            _ => "Неизвестно"
        };
    }
}