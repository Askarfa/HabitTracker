@page "/habits"
@using HabitTracker.Client.Models
@using HabitTracker.Client.Services
@using System.Collections.Generic
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject AuthService Auth

<PageTitle>Все привычки</PageTitle>

<h3>📋 Мои привычки</h3>

@if (!Auth.IsAuthenticated)
{
    <div class="alert alert-info">
        <p>🔐 Пожалуйста, <a href="/login">войдите</a> или <a href="/register">зарегистрируйтесь</a> чтобы управлять привычками.</p>
    </div>
}
else if (habits == null)
{
    <p><span class="spinner-border spinner-border-sm text-primary"></span> Загрузка привычек...</p>
}
else if (habits.Count == 0)
{
    <div class="alert alert-info">
        <p>🎉 У вас пока нет привычек!</p>
        <a href="/habits/create" class="btn btn-success">
            <span class="bi bi-plus-circle"></span> Создать первую привычку
        </a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Название</th>
                    <th>Описание</th>
                    <th>Частота</th>
                    <th>Цель</th>
                    <th>Серия</th>
                    <th>Выполнено</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var habit in habits.OrderBy(h => h.IsCompletedToday).ThenBy(h => h.Name))
                {
                    <tr class="@(habit.IsCompletedToday ? "table-success" : "")">
                        <td><strong>@habit.Name</strong></td>
                        <td class="text-muted small">@(string.IsNullOrEmpty(habit.Description) ? "-" : habit.Description)</td>
                        <td>@GetFrequencyText(habit.Frequency)</td>
                        <td>@habit.TargetStreak дн.</td>
                        <td>
                            <span class="badge @(habit.CurrentStreak >= habit.TargetStreak ? "bg-success" : "bg-warning text-dark")">
                                🔥 @habit.CurrentStreak
                            </span>
                        </td>
                        <td>
                            @if (habit.IsCompletedToday)
                            {
                                <span class="badge bg-success">✅ Да</span>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-success"
                                        @onclick="() => MarkAsCompleted(habit.Id)"
                                        disabled="@isCompleting"
                                        title="Отметить выполненным">
                                    @if (isCompleting && completingId == habit.Id)
                                    {
                                        <span class="spinner-border spinner-border-sm"></span>
                                    }
                                    else
                                    {
                                        <span>✅</span>
                                    }
                                </button>
                            }
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <a href="/habits/edit/@habit.Id"
                                   class="btn btn-sm btn-primary"
                                   title="Редактировать">
                                    ✏️ Изм.
                                </a>
                                <button class="btn btn-sm btn-danger"
                                        @onclick="() => DeleteHabit(habit.Id)"
                                        title="Удалить">
                                    🗑️ Удал.
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="mt-3">
    <a href="/habits/create" class="btn btn-success">
        <span class="bi bi-plus-circle"></span> Добавить привычку
    </a>
    <a href="/" class="btn btn-outline-secondary ms-2">
        <span class="bi bi-house-door"></span> На главную
    </a>
</div>

@code {
    private List<HabitModel>? habits;
    private bool isCompleting = false;
    private Guid completingId;

    protected override async Task OnInitializedAsync()
    {
        if (Auth.IsAuthenticated)
        {
            await LoadHabits();
        }
    }

    private async Task LoadHabits()
    {
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, "/api/habits");

            var token = Auth.GetToken();
            if (!string.IsNullOrEmpty(token))
            {
                request.Headers.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }

            var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                habits = await response.Content.ReadFromJsonAsync<List<HabitModel>>();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                Auth.Logout();
                Navigation.NavigateTo("/login", forceLoad: true);
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Ошибка загрузки: {response.StatusCode} - {error}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки: {ex.Message}");
        }
    }

    private async Task MarkAsCompleted(Guid id)
    {
        isCompleting = true;
        completingId = id;
        StateHasChanged();

        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Post, $"/api/habit-logs/{id}/complete");

            var token = Auth.GetToken();
            if (!string.IsNullOrEmpty(token))
            {
                request.Headers.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }

            var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                await LoadHabits();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                Auth.Logout();
                Navigation.NavigateTo("/login", forceLoad: true);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка: {ex.Message}");
        }
        finally
        {
            isCompleting = false;
            StateHasChanged();
        }
    }

    private async Task DeleteHabit(Guid id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "❌ Удалить эту привычку?\nЭто действие нельзя отменить.");

        if (confirmed)
        {
            try
            {
                using var request = new HttpRequestMessage(HttpMethod.Delete, $"/api/habits/{id}");

                var token = Auth.GetToken();
                if (!string.IsNullOrEmpty(token))
                {
                    request.Headers.Authorization =
                        new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                }

                var response = await Http.SendAsync(request);

                if (response.IsSuccessStatusCode)
                {
                    await LoadHabits();
                }
                else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
                {
                    Auth.Logout();
                    Navigation.NavigateTo("/login", forceLoad: true);
                }
                else
                {
                    var error = await response.Content.ReadAsStringAsync();
                    Console.WriteLine($"Ошибка удаления: {response.StatusCode} - {error}");
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Ошибка: {ex.Message}");
            }
        }
    }

    private string GetFrequencyText(int frequency)
    {
        return frequency switch
        {
            0 => "📅 Ежедневно",
            1 => "🗓️ Еженедельно",
            2 => "📆 Ежемесячно",
            _ => "❓ Неизвестно"
        };
    }
}