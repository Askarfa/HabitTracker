@page "/habits"
@using HabitTracker.Client.Models
@using HabitTracker.Client.Services
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject AuthService Auth

<PageTitle>Мои привычки</PageTitle>

<div class="yougile-container">
    @if (!Auth.IsAuthenticated)
    {
        <div class="text-center p-5 bg-light rounded-4">
            <span class="display-3">🔐</span>
            <h3 class="mt-3">Войдите в аккаунт</h3>
            <p class="text-muted">Чтобы управлять привычками, войдите или зарегистрируйтесь.</p>
            <a href="/login" class="btn btn-primary me-2">Войти</a>
            <a href="/register" class="btn btn-outline-secondary">Регистрация</a>
        </div>
    }
    else if (habits == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-3">Загрузка привычек...</p>
        </div>
    }
    else if (habits.Count == 0)
    {
        <div class="text-center py-5">
            <span class="display-1">✨</span>
            <h3 class="mt-3">У вас пока нет привычек</h3>
            <button class="btn btn-primary mt-3" @onclick="GoToCreate">➕ Создать привычку</button>
        </div>
    }
    else
    {
        <div class="yougile-header">
            <h1 class="yougile-title">📋 Доска привычек</h1>
            <button class="btn-yougile" @onclick="GoToCreate">➕ Новая привычка</button>
        </div>

        <div class="yougile-board" id="yougile-board">
            <!-- Колонка 1: Ожидают выполнения -->
            <div class="yougile-column" data-column="pending">
                <div class="yougile-column-header">
                    <span class="badge bg-warning me-2">⏳</span>
                    <span>Ожидают выполнения</span>
                    <span class="ms-auto badge bg-secondary">@habits.Count(h => !h.IsCompletedToday)</span>
                </div>
                <div class="yougile-column-body">
                    @foreach (var habit in habits.Where(h => !h.IsCompletedToday).OrderBy(h => h.Name))
                    {
                        <div class="yougile-card" draggable="true" data-habit-id="@habit.Id" data-source-column="pending">
                            <h6 class="fw-bold mb-1">@habit.Name</h6>
                            @if (!string.IsNullOrEmpty(habit.Description))
                            {
                                <p class="small text-muted mb-2">@habit.Description</p>
                            }
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="small">🔥 Серия</span>
                                <span class="badge bg-warning text-dark">@habit.CurrentStreak / @habit.TargetStreak</span>
                            </div>
                            <div class="progress mb-2" style="height: 6px;">
                                <div class="progress-bar bg-primary" style="width: @(Math.Min(100, habit.CurrentStreak * 100 / Math.Max(1, habit.TargetStreak)))%"></div>
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-success flex-grow-1" @onclick="() => MarkAsCompleted(habit.Id)" disabled="@isCompleting">
                                    @(isCompleting && completingId == habit.Id ? "..." : "✅ Выполнить")
                                </button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditHabit(habit.Id)">✏️</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteHabit(habit.Id)">🗑️</button>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Колонка 2: Выполнено сегодня -->
            <div class="yougile-column" data-column="completed">
                <div class="yougile-column-header">
                    <span class="badge bg-success me-2">✅</span>
                    <span>Выполнено сегодня</span>
                    <span class="ms-auto badge bg-secondary">@habits.Count(h => h.IsCompletedToday)</span>
                </div>
                <div class="yougile-column-body">
                    @foreach (var habit in habits.Where(h => h.IsCompletedToday).OrderBy(h => h.Name))
                    {
                        <div class="yougile-card completed" draggable="true" data-habit-id="@habit.Id" data-source-column="completed">
                            <h6 class="fw-bold mb-1 text-muted">@habit.Name</h6>
                            @if (!string.IsNullOrEmpty(habit.Description))
                            {
                                <p class="small text-muted mb-2">@habit.Description</p>
                            }
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="small">🔥 Серия</span>
                                <span class="badge bg-success">@habit.CurrentStreak / @habit.TargetStreak</span>
                            </div>
                            <div class="progress mb-2" style="height: 6px;">
                                <div class="progress-bar bg-success" style="width: @(Math.Min(100, habit.CurrentStreak * 100 / Math.Max(1, habit.TargetStreak)))%"></div>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <button class="btn btn-sm btn-outline-warning" @onclick="() => CancelCompletion(habit.Id)">
                                    ↩️ Отменить выполнение
                                </button>
                                <div>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditHabit(habit.Id)">✏️</button>
                                    <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => DeleteHabit(habit.Id)">🗑️</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Колонка 3: Достигли цели -->
            <div class="yougile-column">
                <div class="yougile-column-header">
                    <span class="badge bg-info me-2">🏆</span>
                    <span>Достигли цели</span>
                    <span class="ms-auto badge bg-secondary">@habits.Count(h => h.CurrentStreak >= h.TargetStreak)</span>
                </div>
                <div class="yougile-column-body">
                    @foreach (var habit in habits.Where(h => h.CurrentStreak >= h.TargetStreak).OrderByDescending(h => h.CurrentStreak))
                    {
                        <div class="yougile-card achievement">
                            <h6 class="fw-bold mb-1 text-primary">🏆 @habit.Name</h6>
                            @if (!string.IsNullOrEmpty(habit.Description))
                            {
                                <p class="small text-muted mb-2">@habit.Description</p>
                            }
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="small">🔥 Серия</span>
                                <span class="badge bg-info text-dark">@habit.CurrentStreak / @habit.TargetStreak</span>
                            </div>
                            <div class="progress mb-2" style="height: 6px;">
                                <div class="progress-bar bg-info" style="width: 100%"></div>
                            </div>
                            <div class="text-end small text-success mb-2">🎉 Цель достигнута!</div>
                            <div class="d-flex justify-content-end gap-2">
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditHabit(habit.Id)">✏️ Редактировать</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteHabit(habit.Id)">🗑️</button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

<style>
    /* стили остаются те же, что были */
    .yougile-container {
        padding: 1.5rem;
        background: #f4f5f7;
        min-height: 100vh;
    }

    .yougile-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .yougile-title {
        font-size: 1.5rem;
        font-weight: 600;
        margin: 0;
    }

    .btn-yougile {
        background: #2c3e50;
        color: white;
        border: none;
        padding: 0.5rem 1rem;
        border-radius: 0.375rem;
        font-weight: 500;
        transition: all 0.2s;
    }

        .btn-yougile:hover {
            background: #1e2b36;
            transform: translateY(-1px);
        }

    .yougile-board {
        display: flex;
        gap: 1.5rem;
        overflow-x: auto;
        align-items: flex-start;
    }

    .yougile-column {
        background: #f4f5f7;
        border-radius: 0.5rem;
        width: 320px;
        min-width: 320px;
        display: flex;
        flex-direction: column;
        max-height: calc(100vh - 120px);
    }

    .yougile-column-header {
        padding: 0.75rem;
        background: #fff;
        border-radius: 0.5rem 0.5rem 0 0;
        font-weight: 600;
        border-bottom: 1px solid #e0e0e0;
        display: flex;
        align-items: center;
    }

    .yougile-column-body {
        flex: 1;
        padding: 0.75rem;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .yougile-card {
        background: white;
        border-radius: 0.5rem;
        padding: 0.75rem;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
        transition: all 0.2s;
        border: 1px solid #e9ecef;
        cursor: grab;
    }

        .yougile-card:active {
            cursor: grabbing;
        }

        .yougile-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }

        .yougile-card.completed {
            background: #f8f9fa;
            opacity: 0.85;
        }

        .yougile-card.achievement {
            background: linear-gradient(135deg, #e0f2fe, #ffffff);
            border-left: 4px solid #0dcaf0;
        }

    .progress {
        background-color: #e9ecef;
        border-radius: 9999px;
    }

    .progress-bar {
        border-radius: 9999px;
        transition: width 0.3s ease;
    }

    .btn-success {
        background: linear-gradient(135deg, #10b981, #34d399);
        border: none;
        color: white;
    }

        .btn-success:hover:not(:disabled) {
            transform: scale(1.02);
            box-shadow: 0 2px 8px rgba(16,185,129,0.3);
        }
</style>

@code {
    private List<HabitModel>? habits;
    private bool isCompleting = false;
    private Guid completingId;
    private DotNetObjectReference<HabitsList>? _dotNetHelper;

    protected override async Task OnInitializedAsync()
    {
        if (Auth.IsAuthenticated) await LoadHabits();
        _dotNetHelper = DotNetObjectReference.Create(this);
        await InitDragAndDrop();
    }

    private async Task InitDragAndDrop()
    {
        await JS.InvokeVoidAsync("dragDrop.init", _dotNetHelper);
    }

    private void GoToCreate() => Navigation.NavigateTo("/habits/create");

    private async Task LoadHabits()
    {
        var request = new HttpRequestMessage(HttpMethod.Get, "/api/habits");
        var token = Auth.GetToken();
        if (!string.IsNullOrEmpty(token))
            request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        var response = await Http.SendAsync(request);
        if (response.IsSuccessStatusCode)
            habits = await response.Content.ReadFromJsonAsync<List<HabitModel>>();
        StateHasChanged();
    }

    private async Task MarkAsCompleted(Guid id)
    {
        isCompleting = true;
        completingId = id;
        StateHasChanged();

        var request = new HttpRequestMessage(HttpMethod.Post, $"/api/habit-logs/{id}/complete");
        var token = Auth.GetToken();
        if (!string.IsNullOrEmpty(token))
            request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        var response = await Http.SendAsync(request);
        if (response.IsSuccessStatusCode || response.StatusCode == System.Net.HttpStatusCode.BadRequest)
        {
            var habit = habits?.FirstOrDefault(h => h.Id == id);
            if (habit != null && !habit.IsCompletedToday)
            {
                habit.IsCompletedToday = true;
                habit.CurrentStreak++;
            }
            await LoadHabits();
            StateHasChanged();
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            Console.WriteLine($"Ошибка выполнения: {error}");
        }

        isCompleting = false;
        StateHasChanged();
    }

    private async Task CancelCompletion(Guid habitId)
    {
        var request = new HttpRequestMessage(HttpMethod.Delete, $"/api/habit-logs/{habitId}/cancel");
        var token = Auth.GetToken();
        if (!string.IsNullOrEmpty(token))
            request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        var response = await Http.SendAsync(request);

        if (response.IsSuccessStatusCode || response.StatusCode == System.Net.HttpStatusCode.BadRequest)
        {
            var habit = habits?.FirstOrDefault(h => h.Id == habitId);
            if (habit != null && habit.IsCompletedToday)
            {
                habit.IsCompletedToday = false;
                if (habit.CurrentStreak > 0) habit.CurrentStreak--;
            }
            await LoadHabits();
            StateHasChanged();
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            Console.WriteLine($"Ошибка отмены: {error}");
        }
    }

    private async Task DeleteHabit(Guid id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Удалить привычку?")) return;
        var request = new HttpRequestMessage(HttpMethod.Delete, $"/api/habits/{id}");
        var token = Auth.GetToken();
        if (!string.IsNullOrEmpty(token))
            request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        await Http.SendAsync(request);
        await LoadHabits();
    }

    private void EditHabit(Guid id) => Navigation.NavigateTo($"/habits/edit/{id}");

    [JSInvokable]
    public async Task OnHabitMoved(Guid habitId, string sourceColumn, string targetColumn)
    {
        if (sourceColumn == targetColumn) return;
        if (targetColumn == "completed" && sourceColumn == "pending")
        {
            await MarkAsCompleted(habitId);
        }
        else if (targetColumn == "pending" && sourceColumn == "completed")
        {
            await CancelCompletion(habitId);
        }
    }
}