@page "/"
@using HabitTracker.Client.Models
@using HabitTracker.Client.Services
@inject HttpClient Http
@inject NavigationManager Navigation
@inject AuthService Auth

<PageTitle>Главная - HabitTracker</PageTitle>

<div class="yougile-home">
    <div class="container py-5">
        @if (!Auth.IsAuthenticated)
        {
            <div class="welcome-card mx-auto text-center">
                <div class="mb-4"><span class="display-1">🎯</span></div>
                <h1 class="display-4 fw-bold mb-3">HabitTracker</h1>
                <p class="lead text-muted mb-4">Отслеживайте привычки, достигайте целей и становитесь лучше каждый день</p>
                <div class="d-flex justify-content-center gap-3">
                    <a href="/login" class="btn btn-primary btn-lg px-4 rounded-pill">Вход</a>
                    <a href="/register" class="btn btn-outline-secondary btn-lg px-4 rounded-pill">Регистрация</a>
                </div>
            </div>
        }
        else if (habits == null)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary"></div>
                <p class="mt-3">Загрузка ваших привычек...</p>
            </div>
        }
        else if (habits.Count == 0)
        {
            <div class="welcome-card mx-auto text-center">
                <span class="display-1">✨</span>
                <h3 class="mt-3">У вас пока нет привычек</h3>
                <p class="text-muted">Создайте первую привычку и начните путь к самосовершенствованию</p>
                <a href="/habits/create" class="btn btn-primary mt-3">➕ Создать привычку</a>
            </div>
        }
        else
        {
            <div class="welcome-card mb-5 text-center">
                <h1 class="display-5 fw-bold">Добро пожаловать!</h1>
                <p class="lead text-muted">Рады видеть вас снова. Продолжайте развивать свои привычки.</p>
                <div class="d-flex justify-content-center gap-3 mt-3">
                    <a href="/habits" class="btn btn-primary">📋 Мои привычки</a>
                    <a href="/stats" class="btn btn-outline-secondary">📈 Статистика</a>
                </div>
            </div>
            <h2 class="fw-bold mb-4">📋 Ваши привычки</h2>
            <div class="row g-4">
                @foreach (var habit in habits.Take(5))
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="yougile-card h-100">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="fw-bold mb-0">@habit.Name</h5>
                                <span class="badge @(habit.IsCompletedToday ? "bg-success" : "bg-secondary")">
                                    @(habit.IsCompletedToday ? "Выполнено" : "Ожидает")
                                </span>
                            </div>
                            @if (!string.IsNullOrEmpty(habit.Description))
                            {
                                <p class="text-muted small mb-3">@habit.Description</p>
                            }
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="small fw-semibold">🔥 Серия</span>
                                <span class="badge bg-warning text-dark">@habit.CurrentStreak / @habit.TargetStreak</span>
                            </div>
                            <div class="progress mb-3" style="height: 8px;">
                                <div class="progress-bar" style="width: @(Math.Min(100, habit.CurrentStreak * 100 / Math.Max(1, habit.TargetStreak)))%"></div>
                            </div>
                            <a href="/habits/edit/@habit.Id" class="btn btn-sm btn-outline-secondary w-100">✏️ Редактировать</a>
                        </div>
                    </div>
                }
            </div>
            @if (habits.Count > 5)
            {
                <div class="text-center mt-4"><a href="/habits" class="btn btn-link">Показать все привычки →</a></div>
            }
        }
    </div>
</div>

<style>
    .yougile-home {
        background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%);
        min-height: 100vh;
    }

    .welcome-card {
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(10px);
        border-radius: 2rem;
        padding: 2rem;
        max-width: 800px;
        margin: 0 auto;
        box-shadow: 0 20px 35px -10px rgba(0,0,0,0.1);
        border: 1px solid rgba(255,255,255,0.3);
    }

    .yougile-card {
        background: white;
        border-radius: 1rem;
        padding: 1.25rem;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
        transition: transform 0.1s, box-shadow 0.2s;
        border: 1px solid #e9ecef;
    }

        .yougile-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
        }

    .progress-bar {
        background: linear-gradient(90deg, #6366f1, #8b5cf6);
        border-radius: 9999px;
    }
</style>

@code {
    private List<HabitModel>? habits;

    protected override async Task OnInitializedAsync()
    {
        if (Auth.IsAuthenticated) await LoadHabits();
    }

    private async Task LoadHabits()
    {
        var request = new HttpRequestMessage(HttpMethod.Get, "/api/habits");
        var token = Auth.GetToken();
        if (!string.IsNullOrEmpty(token))
            request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        var response = await Http.SendAsync(request);
        if (response.IsSuccessStatusCode)
            habits = await response.Content.ReadFromJsonAsync<List<HabitModel>>();
        else
            Console.WriteLine($"Ошибка загрузки привычек: {response.StatusCode}");
    }
}