@page "/habits"
@using HabitTracker.Client.Models
@using HabitTracker.Client.Services
@using System.Collections.Generic
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject AuthService Auth

<h3>Мои привычки</h3>

@if (habits == null)
{
    <p><span class="spinner-border spinner-border-sm"></span> Загрузка...</p>
}
else if (habits.Count == 0)
{
    <div class="alert alert-info">
        У вас пока нет привычек. <a href="/habits/create">Создайте первую!</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Название</th>
                    <th>Описание</th>
                    <th>Частота</th>
                    <th>Цель</th>
                    <th>Серия</th>
                    <th>Выполнено</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var habit in habits)
                {
                    <tr>
                        <td><strong>@habit.Name</strong></td>
                        <td class="text-muted small">@habit.Description</td>
                        <td>@GetFrequencyText(habit.Frequency)</td>
                        <td>@habit.TargetStreak дн.</td>
                        <td>
                            <span class="badge @(habit.CurrentStreak >= habit.TargetStreak ? "bg-success" : "bg-warning text-dark")">
                                🔥 @habit.CurrentStreak
                            </span>
                        </td>
                        <td>
                            @if (habit.IsCompletedToday)
                            {
                                <span class="badge bg-success">✅ Да</span>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-success"
                                        @onclick="() => MarkAsCompleted(habit.Id)">
                                    <span class="bi bi-check-circle"></span>
                                </button>
                            }
                        </td>
                        <td>
                            <a href="/habits/edit/@habit.Id" class="btn btn-sm btn-outline-primary me-1">
                                <span class="bi bi-pencil"></span>
                            </a>
                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="() => DeleteHabit(habit.Id)">
                                <span class="bi bi-trash"></span>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="mt-3">
    <a href="/habits/create" class="btn btn-success">
        <span class="bi bi-plus-circle"></span> Добавить привычку
    </a>
</div>

@code {
    private List<HabitModel>? habits;

    protected override async Task OnInitializedAsync()
    {
        await LoadHabits();
    }

    private async Task LoadHabits()
    {
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, "/api/habits");

            var token = Auth.GetToken();
            if (!string.IsNullOrEmpty(token))
            {
                request.Headers.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                habits = await response.Content.ReadFromJsonAsync<List<HabitModel>>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки: {ex.Message}");
        }
    }

    private async Task MarkAsCompleted(Guid id)
    {
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Post, $"/api/habit-logs/{id}/complete");

            var token = Auth.GetToken();
            if (!string.IsNullOrEmpty(token))
            {
                request.Headers.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                await LoadHabits();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка: {ex.Message}");
        }
    }

    private async Task DeleteHabit(Guid id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Удалить эту привычку?");

        if (confirmed)
        {
            try
            {
                using var request = new HttpRequestMessage(HttpMethod.Delete, $"/api/habits/{id}");

                var token = Auth.GetToken();
                if (!string.IsNullOrEmpty(token))
                {
                    request.Headers.Authorization =
                        new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                }

                var response = await Http.SendAsync(request);
                if (response.IsSuccessStatusCode)
                {
                    await LoadHabits();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Ошибка: {ex.Message}");
            }
        }
    }

    private string GetFrequencyText(int frequency)
    {
        return frequency switch
        {
            0 => "Ежедневно",
            1 => "Еженедельно",
            2 => "Ежемесячно",
            _ => "Неизвестно"
        };
    }
}