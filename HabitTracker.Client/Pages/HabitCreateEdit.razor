@page "/habits/create"
@page "/habits/edit/{Id:guid}"
@using HabitTracker.Client.Models
@using HabitTracker.Client.Services
@inject HttpClient Http
@inject NavigationManager Navigation
@inject AuthService Auth

<PageTitle>@(isEdit ? "Редактирование" : "Создание") привычки</PageTitle>

<h3>@(isEdit ? "✏️ Редактирование" : "➕ Создание")</h3>

@if (isLoading)
{
    <div class="text-center">Загрузка...</div>
}
else
{
    <EditForm Model="@habitModel" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />
        <div class="mb-3">
            <label class="form-label">Название *</label>
            <InputText @bind-Value="habitModel.Name" class="form-control" required />
            <ValidationMessage For="@(() => habitModel.Name)" class="text-danger" />
        </div>
        <div class="mb-3">
            <label class="form-label">Описание</label>
            <InputTextArea @bind-Value="habitModel.Description" class="form-control" rows="3" />
        </div>
        <div class="mb-3">
            <label class="form-label">Частота</label>
            <InputSelect @bind-Value="habitModel.Frequency" class="form-select">
                <option value="0">Ежедневно</option>
                <option value="1">Еженедельно</option>
                <option value="2">Ежемесячно</option>
            </InputSelect>
        </div>
        <div class="mb-3">
            <label class="form-label">Цель (дней)</label>
            <InputNumber @bind-Value="habitModel.TargetStreak" class="form-control" min="1" max="365" />
            <ValidationMessage For="@(() => habitModel.TargetStreak)" class="text-danger" />
        </div>
        <button type="submit" class="btn btn-primary" disabled="@isSaving">@(isSaving ? "Сохранение..." : (isEdit ? "Сохранить" : "Создать"))</button>
        <a href="/habits" class="btn btn-secondary">Отмена</a>
    </EditForm>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}

@code {
    [Parameter] public Guid? Id { get; set; }
    private HabitModel habitModel = new();
    private bool isEdit = false;
    private bool isLoading = false;
    private bool isSaving = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue) { isEdit = true; await LoadHabit(Id.Value); }
    }

    private async Task LoadHabit(Guid id)
    {
        isLoading = true;
        StateHasChanged();
        try
        {
            var request = new HttpRequestMessage(HttpMethod.Get, $"/api/habits/{id}");
            var token = Auth.GetToken();
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var loaded = await response.Content.ReadFromJsonAsync<HabitModel>();
                if (loaded != null) habitModel = loaded;
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                await Auth.Logout();
                Navigation.NavigateTo("/login");
            }
            else errorMessage = "Не удалось загрузить привычку";
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { isLoading = false; StateHasChanged(); }
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(habitModel.Name))
        {
            errorMessage = "Название обязательно";
            return;
        }
        if (habitModel.TargetStreak < 1) habitModel.TargetStreak = 1;
        isSaving = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            object dto;
            HttpMethod method;
            string url;
            if (isEdit)
            {
                url = $"/api/habits/{Id}";
                method = HttpMethod.Put;
                dto = new UpdateHabitDto
                    {
                        Name = habitModel.Name,
                        Description = habitModel.Description,
                        Frequency = habitModel.Frequency,
                        TargetStreak = habitModel.TargetStreak
                    };
            }
            else
            {
                url = "/api/habits";
                method = HttpMethod.Post;
                dto = new CreateHabitDto
                    {
                        Name = habitModel.Name,
                        Description = habitModel.Description,
                        Frequency = habitModel.Frequency,
                        TargetStreak = habitModel.TargetStreak
                    };
            }

            var request = new HttpRequestMessage(method, url);
            request.Content = JsonContent.Create(dto);
            var token = Auth.GetToken();
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
                Navigation.NavigateTo("/habits");
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                await Auth.Logout();
                Navigation.NavigateTo("/login");
            }
            else
            {
                var err = await response.Content.ReadAsStringAsync();
                errorMessage = $"Ошибка сервера: {err}";
            }
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { isSaving = false; StateHasChanged(); }
    }
}